---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { SITE, CATEGORIES } from '../../config';
// Astro 5 compatible

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const category = CATEGORIES.find(c => c.slug === post.data.category);
const canonicalUrl = `${SITE.url}/blog/${post.slug}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.metaDescription || post.data.description,
  "author": {
    "@type": "Organization",
    "name": "Zently",
    "url": SITE.parentUrl,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Zently",
    "logo": {
      "@type": "ImageObject",
      "url": SITE.logo,
    }
  },
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
  "image": post.data.image || SITE.logo,
  "url": canonicalUrl,
  "mainEntityOfPage": canonicalUrl,
};
---

<Layout
  title={post.data.metaTitle || post.data.title}
  description={post.data.metaDescription || post.data.description}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  canonical={canonicalUrl}
  type="article"
  pubDate={post.data.pubDate}
  author={post.data.author}
>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <!-- Breadcrumb -->
  <nav aria-label="Fil d'ariane" style="padding: 1rem 0; border-bottom: 1px solid var(--border); background: var(--bg-soft);">
    <div class="container" style="font-size: 0.85rem; color: var(--text-muted); display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <a href="/" style="color: var(--text-muted);">Blog</a>
      <span>›</span>
      {category && <a href={`/category/${category.slug}`} style="color: var(--text-muted);">{category.label}</a>}
      <span>›</span>
      <span style="color: var(--text);">{post.data.title}</span>
    </div>
  </nav>

  <!-- Article -->
  <article style="padding: 3rem 0;">
    <div class="container" style="max-width: var(--content-width); margin: 0 auto;">

      <!-- Meta -->
      <div style="display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap;">
        {category && (
          <a href={`/category/${category.slug}`} class="badge badge-category" style="text-decoration: none;">
            {category.label}
          </a>
        )}
        {post.data.isNew && <span class="badge badge-new">Nouveau</span>}
      </div>

      <!-- Titre -->
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.25rem); color: var(--primary); margin-bottom: 1rem; line-height: 1.2;">
        {post.data.title}
      </h1>

      <!-- Infos article -->
      <div style="display: flex; gap: 1.5rem; align-items: center; font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem; font-family: var(--font-display); flex-wrap: wrap;">
        <span>Par {post.data.author}</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        <span>{post.data.readingTime || 5} min de lecture</span>
      </div>

      <!-- Image principale -->
      {post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt || post.data.title}
          width="760"
          height="430"
          loading="eager"
          style="width: 100%; border-radius: 8px; margin-bottom: 2.5rem; object-fit: cover; max-height: 430px;"
        />
      )}

      <!-- Vidéo YouTube -->
      {post.data.youtubeUrl && (
        <div style="position: relative; padding-bottom: 56.25%; height: 0; margin-bottom: 2.5rem; border-radius: 8px; overflow: hidden;">
          <iframe
            src={post.data.youtubeUrl}
            title={post.data.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
          />
        </div>
      )}

      <!-- Contenu -->
      <div class="prose">
        <Content />
      </div>

      <!-- CTA personnalisé ou défaut -->
      <div style="background: var(--bg-soft); border: 1px solid var(--border); border-left: 4px solid var(--accent); border-radius: 6px; padding: 1.5rem; margin-top: 3rem;">
        <p style="font-family: var(--font-display); font-weight: 600; color: var(--primary); margin-bottom: 0.5rem;">
          {post.data.cta?.label || SITE.cta.label}
        </p>
        <a href={post.data.cta?.url || SITE.cta.url} class="btn btn-primary" style="margin-top: 0.75rem;">
          Essayer gratuitement →
        </a>
      </div>

    </div>
  </article>

</Layout>

<style is:global>
  .prose {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }
  .prose h2 {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    color: var(--primary);
  }
  .prose h3 {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
  }
  .prose p { margin-bottom: 1.25rem; }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose li { margin-bottom: 0.4rem; }
  .prose a { color: var(--secondary); }
  .prose a:hover { text-decoration: underline; }
  .prose strong { color: var(--primary); font-weight: 600; }
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }
  .prose th {
    background: var(--bg-soft);
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    text-align: left;
    font-family: var(--font-display);
  }
  .prose td {
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
  }
  .prose blockquote {
    border-left: 4px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>
