---
import { SITE } from '../config';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  canonical?: string;
  type?: string;
  pubDate?: Date;
  author?: string;
}

const {
  title = SITE.name,
  description = SITE.description,
  image,
  imageAlt = '',
  canonical = Astro.url.href,
  type = 'website',
  pubDate,
  author = 'Équipe Zently',
} = Astro.props;

const fullTitle = title === SITE.name ? title : `${title} — ${SITE.name}`;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#1E3A5F" />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="google-site-verification" content="SokqguVP3XMq9A3Xbp-pzCoJowj8NDuhaDwLPwc-kuE" />
  <meta name="author" content={author} />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:locale" content="fr_FR" />
  {image && <meta property="og:image" content={image} />}
  {image && <meta property="og:image:alt" content={imageAlt} />}

  <!-- Twitter Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  {image && <meta name="twitter:image" content={image} />}
  {image && <meta name="twitter:image:alt" content={imageAlt} />}

  <!-- Article specific -->
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {type === 'article' && <meta property="article:author" content={author} />}

  <!-- Favicon -->
  <link rel="icon" href={SITE.favicon} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title={SITE.name} href="/rss.xml" />

  <style is:global>
    :root {
      --primary: #1E3A5F;
      --secondary: #4A90D9;
      --accent: #F97316;
      --success: #22C55E;
      --bg: #ffffff;
      --bg-soft: #F8FAFC;
      --text: #1a1a2e;
      --text-muted: #64748b;
      --border: #e2e8f0;
      --font-display: 'Space Grotesk', sans-serif;
      --font-body: 'Inter', sans-serif;
      --max-width: 1100px;
      --content-width: 760px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 16px; scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--text);
      background: var(--bg);
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }

    h1, h2, h3, h4 {
      font-family: var(--font-display);
      font-weight: 700;
      line-height: 1.25;
      color: var(--primary);
    }

    a { color: var(--secondary); text-decoration: none; }
    a:hover { text-decoration: underline; }

    img { max-width: 100%; height: auto; display: block; }

    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    .btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: opacity 0.2s;
      text-decoration: none;
    }
    .btn:hover { opacity: 0.88; text-decoration: none; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-secondary { background: transparent; color: var(--primary); border: 2px solid var(--primary); }

    .badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 600;
      font-family: var(--font-display);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .badge-new { background: #FEF3C7; color: #92400E; }
    .badge-category { background: #EFF6FF; color: var(--primary); }
  </style>
    <slot name="head" />
</head>
<body>

  <!-- Header -->
  <header style="border-bottom: 1px solid var(--border); padding: 1rem 0; position: sticky; top: 0; background: #fff; z-index: 100;">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between; gap: 1rem;">
      <a href="/" aria-label="Accueil Blog Zently">
        <img
          src={SITE.logo}
          alt="Zently"
          width="120"
          height="32"
          loading="eager"
        />
      </a>
      <nav aria-label="Navigation principale" style="display: flex; gap: 1.5rem; align-items: center;">
        <a href="/" style="font-family: var(--font-display); font-size: 0.9rem; color: var(--text-muted);">Articles</a>
        <a href={SITE.parentUrl} style="font-family: var(--font-display); font-size: 0.9rem; color: var(--text-muted);">zently.fr</a>
        <a href={SITE.cta.url} class="btn btn-primary" style="padding: 0.5rem 1rem; font-size: 0.875rem;">
          {SITE.cta.label}
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer style="border-top: 1px solid var(--border); padding: 3rem 0; margin-top: 4rem; background: var(--bg-soft);">
    <div class="container">
      <div style="display: flex; flex-wrap: wrap; gap: 2rem; justify-content: space-between; align-items: flex-start;">
        <div>
          <img src={SITE.logo} alt="Zently" width="100" height="28" loading="lazy" />
          <p style="margin-top: 0.75rem; font-size: 0.875rem; color: var(--text-muted); max-width: 280px;">
            Ressources factuelles pour propriétaires de location meublée.
          </p>
        </div>
        <div style="display: flex; gap: 3rem; flex-wrap: wrap;">
          <div>
            <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.875rem; margin-bottom: 0.75rem; color: var(--primary);">Outils Zently</p>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.4rem;">
              <li><a href="https://zently.fr/guard" style="font-size: 0.875rem; color: var(--text-muted);">Guard</a></li>
              <li><a href="https://zently.fr/clansync" style="font-size: 0.875rem; color: var(--text-muted);">CleanSync</a></li>
              <li><a href="https://zently.fr/radar" style="font-size: 0.875rem; color: var(--text-muted);">Radar</a></li>
              <li><a href="https://zently.fr/briefing" style="font-size: 0.875rem; color: var(--text-muted);">Briefing</a></li>
            </ul>
          </div>
          <div>
            <p style="font-family: var(--font-display); font-weight: 700; font-size: 0.875rem; margin-bottom: 0.75rem; color: var(--primary);">Blog</p>
            <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.4rem;">
              <li><a href="/category/location-courte-duree" style="font-size: 0.875rem; color: var(--text-muted);">Location courte durée</a></li>
              <li><a href="/category/fiscalite-et-chiffres" style="font-size: 0.875rem; color: var(--text-muted);">Fiscalité & chiffres</a></li>
              <li><a href="/category/reglementation" style="font-size: 0.875rem; color: var(--text-muted);">Réglementation</a></li>
              <li><a href="/rss.xml" style="font-size: 0.875rem; color: var(--text-muted);">RSS Feed</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
        <p style="font-size: 0.8rem; color: var(--text-muted);">© 2026 OMNIA SAS — SIREN 845 111 186 — Strasbourg</p>
        <div style="display: flex; gap: 1.5rem;">
          <a href="https://zently.fr/mentions-legales" style="font-size: 0.8rem; color: var(--text-muted);">Mentions légales</a>
          <a href="https://zently.fr/confidentialite" style="font-size: 0.8rem; color: var(--text-muted);">Confidentialité</a>
          <a href="mailto:hello@zently.fr" style="font-size: 0.8rem; color: var(--text-muted);">Contact</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>
